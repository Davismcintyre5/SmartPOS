{
  "expo": {
    "name": "SmartPOS",
    "slug": "smartpos-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#2563eb",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smartpos.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "SmartPOS needs camera access to scan barcodes."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563eb"
      },
      "package": "com.smartpos.mobile",
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-camera",
      "expo-av",
      "expo-local-authentication",
      "expo-notifications",
      "expo-audio"
    ],
    "extra": {
      "eas": {
        "projectId": "eb5ff8d0-a81d-4a4f-844e-61b91030a89f"
      }
    }
  }
}
